{
  "manifest_version": 3,
  "name": "QuickJump Pro",
  "version": "1.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
    "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
  {
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  }
}
}

